---
import Layout from "../../../layouts/Layout.astro";
import { updateEvent, getEventById } from "../../../js/backend.mjs";
let pbMessage = "";

const id = Astro.params.id;

const event = await getEventById(id);

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    console.log(formData);
    const result = await updateEvent(id, formData);
    pbMessage = result.message;
} else {
    console.log("GET request");
}
---

<Layout title="Modifier un événement">
    <h1 class="text-3xl">Modifier un événement</h1>
    {pbMessage && <p class="text-green-500">{pbMessage}</p>}

    <form
        class="flex flex-col p-4"
        method="post"
        action="/agenda/update"
        enctype="multipart/form-data"
    >
        <input
            type="text"
            name="id"
            placeholder="ID"
            value={event?.id}
            class="border
            my-4
            p-2
            rounded-md"
        />
        <select name="categorie" class="border my-4 p-2">
            <option value="theatre">Théâtre</option>
            <option value="musique">Musique</option>
            <option value="danse">Danse</option>
        </select>
        <input
            type="text"
            name="Titre"
            placeholder="Titre"
            value={event?.Titre}
            class="border
            my-4
            p-2
            rounded-md"
        />
        <input
            type="date"
            name="date_evenement"
            placeholder="Date"
            value={event?.date_evenement}
            class="
            border
            my-4
            p-2
            rounded-md"
        />
        <input
            type="submit"
            value="Modifier"
            class="bg-slate-500 rounded-lg p-5"
        />
    </form>
</Layout>
